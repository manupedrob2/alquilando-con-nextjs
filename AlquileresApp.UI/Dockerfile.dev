# Backend Dockerfile para desarrollo
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS base
WORKDIR /app
EXPOSE 5234

# Copiar archivos de proyecto
COPY ["AlquileresApp.UI/AlquileresApp.UI.csproj", "AlquileresApp.UI/"]
COPY ["AlquileresApp.Core/AlquileresApp.Core.csproj", "AlquileresApp.Core/"]
COPY ["AlquileresApp.Data/AlquileresApp.Data.csproj", "AlquileresApp.Data/"]

# Restaurar paquetes
WORKDIR "/app/AlquileresApp.UI"
RUN dotnet restore "AlquileresApp.UI.csproj"

# Copiar todo el código fuente
COPY . .

# Crear directorio para la base de datos
RUN mkdir -p /app/data
RUN chmod 777 /app/data

# Variables de entorno - SOLO HTTP
ENV ASPNETCORE_URLS=http://+:5234
ENV ASPNETCORE_ENVIRONMENT=Development

# Usar dotnet watch para desarrollo en caliente
ENTRYPOINT ["dotnet", "watch", "run", "--urls", "http://+:5234"]
